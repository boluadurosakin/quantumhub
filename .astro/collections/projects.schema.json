{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "stack": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "production",
        "experimental",
        "archived"
      ]
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "category": {
      "type": "string",
      "enum": [
        "ai",
        "automation",
        "web",
        "backend",
        "devops",
        "data",
        "api",
        "tool"
      ]
    },
    "github": {
      "type": "string",
      "format": "uri"
    },
    "demo": {
      "type": "string",
      "format": "uri"
    },
    "cover": {
      "type": "string"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "stack",
    "status",
    "date",
    "category"
  ]
}