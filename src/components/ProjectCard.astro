---
interface Props {
  title:       string;
  description: string;
  stack:       string[];
  status:      'production' | 'experimental' | 'archived';
  category:    string;
  slug:        string;
  featured?:   boolean;
  github?:     string;
  demo?:       string;
}

const {
  title,
  description,
  stack,
  status,
  category,
  slug,
  featured = false,
  github,
  demo,
} = Astro.props;

const statusLabel: Record<string, string> = {
  production:   'production',
  experimental: 'experimental',
  archived:     'archived',
};
---

<article
  class:list={[
    'card group relative flex flex-col p-5 gap-4',
    'hover:shadow-glow',
    featured && 'ring-1 ring-accent/20',
  ]}
>
  <!-- Top row: category + status -->
  <div class="flex items-center justify-between gap-2">
    <span class="badge-category">{category}</span>
    <span class:list={[`badge-${status}`]}>
      {status === 'production' && (
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse-slow"></span>
      )}
      {statusLabel[status]}
    </span>
  </div>

  <!-- Title + description -->
  <div class="flex-1">
    <h3 class="font-display font-semibold text-base text-ink-primary mb-1.5 group-hover:text-accent transition-colors">
      <a href={`/projects/${slug}`} class="stretched-link after:absolute after:inset-0">
        {title}
      </a>
    </h3>
    <p class="text-sm text-ink-secondary leading-relaxed line-clamp-2">
      {description}
    </p>
  </div>

  <!-- Stack -->
  <div class="flex flex-wrap gap-1.5">
    {stack.slice(0, 4).map((tech) => (
      <span class="font-mono text-2xs px-2 py-0.5 rounded bg-surface-overlay text-ink-muted border border-surface-border">
        {tech}
      </span>
    ))}
    {stack.length > 4 && (
      <span class="font-mono text-2xs px-2 py-0.5 rounded bg-surface-overlay text-ink-disabled border border-surface-border">
        +{stack.length - 4}
      </span>
    )}
  </div>

  <!-- Action links — rendered above the stretched-link overlay -->
  <div class="relative z-10 flex items-center gap-3 pt-1 border-t border-surface-border">
    <a
      href={`/projects/${slug}`}
      class="link-arrow text-xs"
    >
      Case study
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
        <path d="M2 6h8M6.5 3l3.5 3-3.5 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    {github && (
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="ml-auto text-ink-disabled hover:text-ink-secondary transition-colors"
        aria-label="View source on GitHub"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </a>
    )}

    {demo && (
      <a
        href={demo}
        target="_blank"
        rel="noopener noreferrer"
        class="text-ink-disabled hover:text-ink-secondary transition-colors"
        aria-label="View live demo"
      >
        <svg width="14" height="14" viewBox="0 0 12 12" fill="none">
          <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    )}
  </div>
</article>
