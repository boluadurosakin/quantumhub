---
const year = new Date().getFullYear();

const LINKS = {
  nav: [
    { href: '/projects', label: 'Projects' },
    { href: '/case-studies', label: 'Case Studies' },
    { href: '/about',    label: 'About' },
    { href: '/contact',  label: 'Contact' },
  ],
  external: [
    { href: 'https://github.com/boluadurosakin',      label: 'GitHub' },
    { href: 'https://x.com/0xQuantum_',       label: 'X' },
  ],
};
---

<footer class="border-t border-surface-border mt-24">
  <div class="container-main py-12">

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-10">

      <!-- Brand column -->
      <div class="sm:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 mb-3 group">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
            <rect x="1" y="1" width="18" height="18" rx="3" stroke="#06b6d4" stroke-width="1.5"/>
            <path d="M6 10 L10 6 L14 10 L10 14 Z" fill="#06b6d4" opacity="0.8"/>
            <rect x="11" y="11" width="4" height="4" rx="1" fill="#06b6d4"/>
          </svg>
          <span class="font-display font-semibold text-sm text-ink-primary">
            quantumhub<span class="text-accent">.me</span>
          </span>
        </a>
        <p class="text-xs text-ink-muted leading-relaxed max-w-xs">
          Designing intelligent workflows, AI-powered operational systems, and scalable automation infrastructure.
        </p>
      </div>

      <!-- Nav links -->
      <div>
        <p class="label-mono mb-3">Pages</p>
        <ul class="flex flex-col gap-1.5">
          {LINKS.nav.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-ink-secondary hover:text-ink-primary transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- External links -->
      <div>
        <p class="label-mono mb-3">Connect</p>
        <ul class="flex flex-col gap-1.5">
          {LINKS.external.map(({ href, label }) => (
            <li>
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm text-ink-secondary hover:text-ink-primary transition-colors"
              >
                {label}
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none" class="opacity-40">
                  <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>
<div class="pt-10 mt-10 text-center">
  <p class="text-sm text-ink-secondary mb-4">
    Explore the architecture, workflows, and engineering decisions behind my flagship systems.
  </p>

  <a
    href="/case-studies"
    class="inline-flex items-center gap-2 px-4 py-2 rounded border border-surface-border hover:border-accent transition-colors"
  >
    View Case Studies
    →
  </a>
</div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-surface-border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2">
      <p class="font-mono text-2xs text-ink-disabled">
        © {year} QuantumHub — AI Automation & Systems Engineer
      </p>
      <p class="font-mono text-2xs text-ink-disabled">
        <span class="text-accent/60">→</span> open to collaborations
      </p>
    </div>

  </div>



</footer>