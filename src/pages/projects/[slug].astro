---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props:  { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const {
  title,
  description,
  stack,
  status,
  category,
  date,
  github,
  demo,
  featured,
  tags,
} = project.data;

// Get more projects for the related section
const all = await getCollection('projects', ({ data }) => !data.draft);
const related = all
  .filter((p) => p.id !== project.id && p.data.category === category)
  .slice(0, 3);
---

<BaseLayout title={title} description={description}>

  <!-- Breadcrumb -->
  <div class="border-b border-surface-border">
    <div class="container-main py-3 flex items-center gap-2 text-xs text-ink-muted font-mono">
      <a href="/" class="hover:text-ink-secondary transition-colors">~</a>
      <span>/</span>
      <a href="/projects" class="hover:text-ink-secondary transition-colors">projects</a>
      <span>/</span>
      <span class="text-ink-secondary">{project.id}</span>
    </div>
  </div>

  <div class="container-main py-12">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-10 items-start">

      <!-- Main content -->
      <div>
        <!-- Badges -->
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="badge-category">{category}</span>
          <span class:list={[`badge-${status}`]}>
            {status === 'production' && (
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse-slow"></span>
            )}
            {status}
          </span>
          {featured && <span class="badge" style="background:rgba(6,182,212,0.08);color:#06b6d4;border-color:rgba(6,182,212,0.2)">★ featured</span>}
        </div>

        <!-- Title -->
        <h1 class="font-display font-bold text-3xl sm:text-4xl text-ink-primary leading-tight mb-3">
          {title}
        </h1>
        <p class="text-lg text-ink-secondary leading-relaxed mb-8">
          {description}
        </p>

        <!-- Markdown body -->
        <div class="
          prose prose-invert max-w-none
          prose-headings:font-display prose-headings:font-semibold prose-headings:text-ink-primary
          prose-p:text-ink-secondary prose-p:leading-relaxed
          prose-a:text-accent prose-a:no-underline hover:prose-a:underline
          prose-code:font-mono prose-code:text-accent prose-code:bg-surface-raised prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:before:content-none prose-code:after:content-none
          prose-pre:bg-surface-raised prose-pre:border prose-pre:border-surface-border
          prose-strong:text-ink-primary
          prose-li:text-ink-secondary
          prose-hr:border-surface-border
        ">
          <Content />
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lg:sticky lg:top-28 flex flex-col gap-4">

        <!-- Meta card -->
        <div class="card p-5 flex flex-col gap-4">
          <p class="label-mono">Project info</p>

          <dl class="flex flex-col gap-3 text-sm">
            <div>
              <dt class="text-ink-disabled text-xs font-mono mb-0.5">Date</dt>
              <dd class="text-ink-secondary">
                <time datetime={date.toISOString()}>
                  {date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
              </dd>
            </div>
            <div>
              <dt class="text-ink-disabled text-xs font-mono mb-0.5">Category</dt>
              <dd class="text-ink-secondary">{category}</dd>
            </div>
            <div>
              <dt class="text-ink-disabled text-xs font-mono mb-1">Stack</dt>
              <dd class="flex flex-wrap gap-1.5">
                {stack.map((tech) => (
                  <span class="font-mono text-2xs px-2 py-0.5 rounded bg-surface-overlay text-ink-muted border border-surface-border">
                    {tech}
                  </span>
                ))}
              </dd>
            </div>
            {tags.length > 0 && (
              <div>
                <dt class="text-ink-disabled text-xs font-mono mb-1">Tags</dt>
                <dd class="flex flex-wrap gap-1.5">
                  {tags.map((tag) => (
                    <span class="font-mono text-2xs px-2 py-0.5 rounded bg-surface-overlay text-ink-disabled border border-surface-border">
                      #{tag}
                    </span>
                  ))}
                </dd>
              </div>
            )}
          </dl>
        </div>

        <!-- Action links -->
        {(github || demo) && (
          <div class="card p-5 flex flex-col gap-2">
            <p class="label-mono mb-1">Links</p>
            {github && (
              <a
                href={github}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2.5 text-sm text-ink-secondary hover:text-ink-primary transition-colors py-1"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="flex-shrink-0">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
                View source
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none" class="ml-auto opacity-40">
                  <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            )}
            {demo && (
              <a
                href={demo}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2.5 text-sm text-accent hover:text-accent/80 transition-colors py-1"
              >
                <svg width="14" height="14" viewBox="0 0 12 12" fill="none">
                  <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.3"/>
                  <path d="M4 6l1.5 1.5L8 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Live demo
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none" class="ml-auto opacity-40">
                  <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4.5M9.5 2.5V7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            )}
          </div>
        )}

        <!-- Back link -->
        <a href="/projects" class="flex items-center gap-2 text-sm text-ink-muted hover:text-ink-secondary transition-colors px-1">
          <svg width="14" height="14" viewBox="0 0 12 12" fill="none">
            <path d="M10 6H2M5.5 9L2 6l3.5-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          All projects
        </a>

      </aside>
    </div>

    <!-- Related projects -->
    {related.length > 0 && (
      <div class="mt-16 pt-12 border-t border-surface-border">
        <p class="section-label label-mono mb-2">more {category}</p>
        <h2 class="font-display font-semibold text-xl text-ink-primary mb-6">Related Projects</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {related.map((p) => (
            <a href={`/projects/${p.id}`} class="card p-4 group">
              <div class="flex items-center justify-between mb-2">
                <span class="badge-category">{p.data.category}</span>
                <span class:list={[`badge-${p.data.status}`]}>{p.data.status}</span>
              </div>
              <h3 class="font-display font-semibold text-sm text-ink-primary group-hover:text-accent transition-colors mb-1">
                {p.data.title}
              </h3>
              <p class="text-xs text-ink-muted leading-relaxed line-clamp-2">{p.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>

</BaseLayout>