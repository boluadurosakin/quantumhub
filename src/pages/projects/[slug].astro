---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const {
  title,
  description,
  stack,
  status,
  category,
  date,
  github,
  demo,
  featured,
  tags = [],
} = project.data;

const projectDate = new Date(date);

const all = await getCollection('projects', ({ data }) => !data.draft);
const related = all
  .filter((p) => p.id !== project.id && p.data.category === category)
  .slice(0, 3);
---

<BaseLayout title={title} description={description}>

  <!-- Breadcrumb -->
  <div class="border-b border-surface-border">
    <div class="container-main py-3 flex items-center gap-2 text-xs text-ink-muted font-mono">
      <a href="/" class="hover:text-ink-secondary transition-colors">~</a>
      <span>/</span>
      <a href="/projects" class="hover:text-ink-secondary transition-colors">projects</a>
      <span>/</span>
      <span class="text-ink-secondary">{title}</span>
    </div>
  </div>

  <div class="container-main py-12">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-10 items-start">

      <!-- MAIN -->
      <div>
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="badge-category">{category}</span>
          <span class:list={[`badge-${status}`]}>
            {status === 'production' && (
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse-slow"></span>
            )}
            {status}
          </span>
          {featured && <span class="badge">★ featured</span>}
        </div>

        <h1 class="font-display font-bold text-3xl sm:text-4xl text-ink-primary mb-3">
          {title}
        </h1>
        <p class="text-lg text-ink-secondary leading-relaxed mb-8">{description}</p>

        <div class="prose prose-invert max-w-none">
          <Content />
        </div>
      </div>

      <!-- SIDEBAR -->
      <aside class="lg:sticky lg:top-28 flex flex-col gap-4">

        <div class="card p-5 flex flex-col gap-4">
          <p class="label-mono">Project info</p>
          <dl class="flex flex-col gap-3 text-sm">
            <div>
              <dt class="text-ink-disabled text-xs font-mono">Date</dt>
              <dd class="text-ink-secondary">
                <time datetime={projectDate.toISOString()}>
                  {projectDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
              </dd>
            </div>
            <div>
              <dt class="text-ink-disabled text-xs font-mono">Category</dt>
              <dd class="text-ink-secondary">{category}</dd>
            </div>
            <div>
              <dt class="text-ink-disabled text-xs font-mono">Stack</dt>
              <dd class="flex flex-wrap gap-1.5">
                {stack.map((tech) => (
                  <span class="font-mono text-2xs px-2 py-0.5 rounded bg-surface-overlay text-ink-muted border border-surface-border">
                    {tech}
                  </span>
                ))}
              </dd>
            </div>
            {tags?.length > 0 && (
              <div>
                <dt class="text-ink-disabled text-xs font-mono">Tags</dt>
                <dd class="flex flex-wrap gap-1.5">
                  {tags.map((tag) => (
                    <span class="font-mono text-2xs px-2 py-0.5 rounded bg-surface-overlay text-ink-disabled border border-surface-border">
                      #{tag}
                    </span>
                  ))}
                </dd>
              </div>
            )}
          </dl>
        </div>

        {(github || demo) && (
          <div class="card p-5 flex flex-col gap-2">
            <p class="label-mono">Links</p>
            {github && (
              <a href={github} target="_blank" rel="noopener noreferrer" class="text-sm text-ink-secondary hover:text-ink-primary transition-colors">
                View source
              </a>
            )}
            {demo && (
              <a href={demo} target="_blank" rel="noopener noreferrer" class="text-sm text-accent hover:text-accent/80 transition-colors">
                Live demo
              </a>
            )}
          </div>
        )}

        <a href="/projects" class="text-sm text-ink-muted hover:text-ink-secondary transition-colors">
          ← Back to projects
        </a>

      </aside>
    </div>

    {related.length > 0 && (
      <div class="mt-16 pt-12 border-t border-surface-border">
        <h2 class="font-display text-xl mb-6">Related Projects</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {related.map((p) => (
            <a href={`/projects/${p.id}`} class="card p-4">
              <div class="flex justify-between mb-2">
                <span class="badge-category">{p.data.category}</span>
                <span class:list={[`badge-${p.data.status}`]}>{p.data.status}</span>
              </div>
              <h3 class="font-semibold text-sm text-ink-primary">{p.data.title}</h3>
              <p class="text-xs text-ink-muted line-clamp-2">{p.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>

</BaseLayout>