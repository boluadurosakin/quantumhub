---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const studies = await getCollection('caseStudies', ({ data }) => !data.draft);
  return studies.map((study) => ({
    params: { slug: study.id },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);

const { title, description, stack, role, timeline, featured } = study.data;
---

<BaseLayout title={title} description={description}>

  <!-- Breadcrumb -->
  <div class="border-b border-surface-border">
    <div class="container-main py-3 flex items-center gap-2 text-xs font-mono text-ink-muted">
      <a href="/" class="hover:text-ink-secondary transition-colors">~</a>
      <span>/</span>
      <a href="/case-studies" class="hover:text-ink-secondary transition-colors">case-studies</a>
      <span>/</span>
      <span class="text-ink-secondary">{title}</span>
    </div>
  </div>

  <section class="py-14">
    <div class="container-main">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-12 items-start">

        <!-- Main Content -->
        <div>

          {featured && (
            <span class="badge mb-5" style="background:rgba(6,182,212,0.08);color:#06b6d4;border-color:rgba(6,182,212,0.2)">
              ★ flagship system
            </span>
          )}

          <h1 class="font-display font-bold text-4xl text-ink-primary mb-4 leading-tight">
            {title}
          </h1>

          <p class="text-xl text-ink-secondary leading-relaxed max-w-3xl mb-10">
            {description}
          </p>

          <div
            id="case-study-body"
            class="
              prose prose-invert max-w-none
              prose-headings:text-ink-primary
              prose-headings:font-display
              prose-p:text-ink-secondary
              prose-p:leading-relaxed
              prose-li:text-ink-secondary
              prose-strong:text-ink-primary
              prose-a:text-accent
              prose-code:text-accent
              prose-pre:bg-surface-raised
              prose-pre:border
              prose-pre:border-surface-border
            "
          >
            <Content />
          </div>

        </div>

        <!-- Sidebar -->
        <aside class="lg:sticky lg:top-28 flex flex-col gap-4">

          <!-- Project Summary -->
          <div class="card p-5">
            <p class="label-mono mb-4">Project Summary</p>
            <dl class="flex flex-col gap-4 text-sm">
              {role && (
                <div>
                  <dt class="text-xs font-mono text-ink-disabled mb-1">Role</dt>
                  <dd class="text-ink-secondary">{role}</dd>
                </div>
              )}
              {timeline && (
                <div>
                  <dt class="text-xs font-mono text-ink-disabled mb-1">Timeline</dt>
                  <dd class="text-ink-secondary">{timeline}</dd>
                </div>
              )}
              {stack?.length > 0 && (
                <div>
                  <dt class="text-xs font-mono text-ink-disabled mb-2">Technologies</dt>
                  <dd class="flex flex-wrap gap-1.5">
                    {stack.map((tech) => (
                      <span class="font-mono text-2xs px-2 py-0.5 rounded bg-surface-overlay border border-surface-border text-ink-muted">
                        {tech}
                      </span>
                    ))}
                  </dd>
                </div>
              )}
            </dl>
          </div>

          <!-- Capabilities -->
          <div class="card p-5">
            <p class="label-mono mb-4">Capabilities Demonstrated</p>
            <ul class="flex flex-col gap-2 text-sm text-ink-secondary">
              <li>→ Workflow Automation</li>
              <li>→ AI Integration</li>
              <li>→ Backend Engineering</li>
              <li>→ Systems Design</li>
              <li>→ Operational Efficiency</li>
            </ul>
          </div>

          <!-- CTA -->
          <div class="card p-5">
            <p class="label-mono mb-3">Need something similar?</p>
            <p class="text-sm text-ink-secondary leading-relaxed mb-4">
              I design intelligent workflows, automation systems, and AI-powered operational tools for growing teams.
            </p>
            <a href="/contact" class="inline-flex items-center gap-2 text-sm text-accent hover:text-accent/80 transition-colors">
              Start a conversation
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M2 6h8M6.5 3l3.5 3-3.5 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

          <a href="/case-studies" class="flex items-center gap-2 text-sm text-ink-muted hover:text-ink-secondary transition-colors px-1">
            <svg width="14" height="14" viewBox="0 0 12 12" fill="none">
              <path d="M10 6H2M5.5 9L2 6l3.5-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            All case studies
          </a>

        </aside>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  const body = document.getElementById('case-study-body');
  if (!body) throw new Error('No body');

  const headings = body.querySelectorAll('h2, h3');

  headings.forEach((heading, index) => {
    const siblings = [];
    let next = heading.nextElementSibling;
    const level = parseInt(heading.tagName[1]);

    while (next) {
      const nextLevel = next.tagName.match(/^H([23])$/)
        ? parseInt(next.tagName[1])
        : null;
      if (nextLevel !== null && nextLevel <= level) break;
      siblings.push(next);
      next = next.nextElementSibling;
    }

    if (siblings.length === 0) return;

    // Only the first section starts open
    const isFirst = index === 0;

    const wrapper = document.createElement('div');
    wrapper.style.overflow = 'hidden';
    wrapper.style.transition = 'max-height 0.25s ease';
    wrapper.style.maxHeight = isFirst ? '9999px' : '0px';

    siblings[0].parentNode.insertBefore(wrapper, siblings[0]);
    siblings.forEach((el) => wrapper.appendChild(el));

    heading.style.cursor = 'pointer';
    heading.style.userSelect = 'none';
    heading.style.display = 'flex';
    heading.style.alignItems = 'center';
    heading.style.justifyContent = 'space-between';
    heading.style.gap = '8px';

    const chevron = document.createElement('span');
    chevron.innerHTML = `<svg width="14" height="14" viewBox="0 0 12 12" fill="none" style="transition:transform 0.25s ease;flex-shrink:0"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    chevron.style.opacity = '0.4';
    chevron.querySelector('svg').style.transform = isFirst ? 'rotate(0deg)' : 'rotate(-90deg)';
    heading.appendChild(chevron);

    let open = isFirst;

    heading.addEventListener('click', () => {
      open = !open;
      wrapper.style.maxHeight = open ? '9999px' : '0px';
      chevron.querySelector('svg').style.transform = open ? 'rotate(0deg)' : 'rotate(-90deg)';
    });
  });
</script>