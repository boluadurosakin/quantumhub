---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="Senior software engineer focused on backend systems, automation infrastructure, and AI tooling."
>

  <section class="pt-14 pb-16">
    <div class="container-main">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-12 items-start">

        <!-- Bio -->
        <div>
          <p class="section-label label-mono mb-3">about</p>
          <h1 class="font-display font-bold text-4xl text-ink-primary mb-6">
            Building systems<br/>that scale.
          </h1>

          <div class="flex flex-col gap-4 text-ink-secondary leading-relaxed max-w-2xl">
            <p>
              I'm an AI Automation & Systems Engineer focused on designing intelligent workflows, operational systems, and automation infrastructure. I build solutions that reduce manual work, improve decision-making, and help organizations scale efficiently.
            </p>
            <p>
              My home base is <a href="https://quantumhub.me" class="text-accent hover:underline">quantumhub.me</a> —
              Through QuantumHub, I design and prototype AI-powered systems across recruitment, healthcare, agriculture, and business operations. My work combines workflow automation, backend engineering, AI integration, and self-hosted infrastructure.
            </p>
            <p>
              I believe the best systems are invisible. When automation is designed properly, teams spend less time on repetitive work and more time solving meaningful problems.
            </p>
          </div>

          <!-- Principles -->
          <div class="mt-10">
            <p class="section-label label-mono mb-4">principles</p>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {[
                ['Reliability before complexity', 'Automation is only valuable when it works consistently and predictably.'],
                ['Automate repetitive work',      'Human effort should be reserved for decisions, not routine operational tasks.'],
                ['Systems over shortcuts',        'Sustainable growth comes from well-designed systems, not temporary fixes.'],
                ['Scale through automation',      'Technology should multiply human capability, not create more manual processes.'],
                ['Documentation is code',         'Undocumented systems rot. Write as you build.'],
              ].map(([title, body]) => (
                <li class="card p-4">
                  <p class="font-semibold text-sm text-ink-primary mb-1">{title}</p>
                  <p class="text-xs text-ink-muted leading-relaxed">{body}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:sticky lg:top-28 flex flex-col gap-4">

          <div class="card p-5">
            <p class="label-mono mb-4">Currently</p>
            <ul class="flex flex-col gap-3 text-sm">
              <li class="flex items-start gap-2.5">
                <span class="w-1.5 h-1.5 rounded-full bg-accent mt-1.5 flex-shrink-0 animate-pulse-slow"></span>
                <span class="text-ink-secondary">Building AI recruitment systems</span>
              </li>
              <li class="flex items-start gap-2.5">
                <span class="w-1.5 h-1.5 rounded-full bg-surface-muted mt-1.5 flex-shrink-0"></span>
                <span class="text-ink-secondary">Developing workflow automation infrastructure</span>
              </li>
              <li class="flex items-start gap-2.5">
                <span class="w-1.5 h-1.5 rounded-full bg-surface-muted mt-1.5 flex-shrink-0"></span>
                <span class="text-ink-secondary">Open to AI automation & systems projects</span>
              </li>
            </ul>
          </div>

          <div class="card p-5">
            <p class="label-mono mb-4">Focus areas</p>
            <ul class="flex flex-col gap-2">
              {['AI Workflow Automation', 'Systems Engineering', 'Workflow Infrastructure', 'AI Agent & Bot Development', 'Backend Engineering', 'Self-Hosted Infrastructure'].map((area) => (
                <li class="text-sm text-ink-secondary flex items-center gap-2">
                  <span class="text-accent/60 font-mono text-xs">→</span>
                  {area}
                </li>
              ))}
            </ul>
          </div>

          <a
            href="/contact"
            class="card p-5 group hover:border-accent/30 transition-colors"
          >
            <p class="label-mono mb-2">Get in touch</p>
            <p class="text-sm text-ink-secondary leading-relaxed mb-3">
              Interesting project? Let's talk.
            </p>
            <span class="link-arrow text-xs">
              Contact me
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M2 6h8M6.5 3l3.5 3-3.5 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </aside>

      </div>
    </div>
  </section>

</BaseLayout>